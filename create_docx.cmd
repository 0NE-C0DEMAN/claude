echo     def _remove_author_tracked_changes^(self, root^):
echo         ins_tag = f^"{{{self.namespaces['w']}}}ins^"
echo         del_tag = f^"{{{self.namespaces['w']}}}del^"
echo         author_attr = f^"{{{self.namespaces['w']}}}author^"
echo 
echo         for parent in root.iter^(^):
echo             to_remove = []
echo             for child in parent:
echo                 if child.tag == ins_tag and child.get^(author_attr^) == self.author:
echo                     to_remove.append^(child^)
echo             for elem in to_remove:
echo                 parent.remove^(elem^)
echo 
echo         deltext_tag = f^"{{{self.namespaces['w']}}}delText^"
echo         t_tag = f^"{{{self.namespaces['w']}}}t^"
echo 
echo         for parent in root.iter^(^):
echo             to_process = []
echo             for child in parent:
echo                 if child.tag == del_tag and child.get^(author_attr^) == self.author:
echo                     to_process.append^(^(child, list^(parent^).index^(child^)^)^)
echo 
echo             for del_elem, del_index in reversed^(to_process^):
echo                 for elem in del_elem.iter^(^):
echo                     if elem.tag == deltext_tag:
echo                         elem.tag = t_tag
echo 
echo                 for child in reversed^(list^(del_elem^)^):
echo                     parent.insert^(del_index, child^)
echo                 parent.remove^(del_elem^)
echo 
echo     def _extract_text_content^(self, root^):
echo         p_tag = f^"{{{self.namespaces['w']}}}p^"
echo         t_tag = f^"{{{self.namespaces['w']}}}t^"
echo 
echo         paragraphs = []
echo         for p_elem in root.findall^(f^".//{p_tag}^"^):
