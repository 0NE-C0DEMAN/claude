echo     def _generate_detailed_diff^(self, original_text, modified_text^):
echo         error_parts = [
echo             f^"FAILED - Document text doesn't match after removing {self.author}'s tracked changes^",
echo             ^"^",
echo             ^"Likely causes:^",
echo             ^"  1. Modified text inside another author's ^<w:ins^> or ^<w:del^> tags^",
echo             ^"  2. Made edits without proper tracked changes^",
echo             ^"  3. Didn't nest ^<w:del^> inside ^<w:ins^> when deleting another's insertion^",
echo             ^"^",
echo             ^"For pre-redlined documents, use correct patterns:^",
echo             ^"  - To reject another's INSERTION: Nest ^<w:del^> inside their ^<w:ins^>^",
echo             ^"  - To restore another's DELETION: Add new ^<w:ins^> AFTER their ^<w:del^>^",
echo             ^"^",
echo         ]
echo 
echo         git_diff = self._get_git_word_diff^(original_text, modified_text^)
echo         if git_diff:
echo             error_parts.extend^([^"Differences:^", ^"============^", git_diff]^)
echo         else:
echo             error_parts.append^(^"Unable to generate word diff ^(git not available^)^"^)
echo 
echo         return ^"\n^".join^(error_parts^)
echo 
echo     def _get_git_word_diff^(self, original_text, modified_text^):
echo         try:
echo             with tempfile.TemporaryDirectory^(^) as temp_dir:
echo                 temp_path = Path^(temp_dir^)
echo 
echo                 original_file = temp_path / ^"original.txt^"
echo                 modified_file = temp_path / ^"modified.txt^"
echo 
echo                 original_file.write_text^(original_text, encoding=^"utf-8^"^)
echo                 modified_file.write_text^(modified_text, encoding=^"utf-8^"^)
echo 
echo                 result = subprocess.run^(
echo                     [
echo                         ^"git^",
echo                         ^"diff^",
echo                         ^"--word-diff=plain^",
echo                         ^"--word-diff-regex=.^",  
echo                         ^"-U0^",  
echo                         ^"--no-index^",
echo                         str^(original_file^),
echo                         str^(modified_file^),
echo                     ],
echo                     capture_output=True,
echo                     text=True,
echo                 ^)
echo 
echo                 if result.stdout.strip^(^):
echo                     lines = result.stdout.split^(^"\n^"^)
echo                     content_lines = []
echo                     in_content = False
echo                     for line in lines:
echo                         if line.startswith^(^"@@^"^):
