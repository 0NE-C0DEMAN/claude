echo             for t_elem in p_elem.findall^(f^".//{t_tag}^"^):
echo                 if t_elem.text:
echo                     text_parts.append^(t_elem.text^)
echo             paragraph_text = ^"^".join^(text_parts^)
echo             if paragraph_text:
echo                 paragraphs.append^(paragraph_text^)
echo 
echo         return ^"\n^".join^(paragraphs^)
echo 
