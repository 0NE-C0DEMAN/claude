echo 
echo # DOCX creation, editing, and analysis
echo 
echo ## Overview
echo 
echo A .docx file is a ZIP archive containing XML files.
echo 
echo ## Quick Reference
echo 
echo ^| Task ^| Approach ^|
echo ^|------^|----------^|
echo ^| Read/analyze content ^| `pandoc` or unpack for raw XML ^|
echo ^| Create new document ^| Use `docx-js` - see Creating New Documents below ^|
echo ^| Edit existing document ^| Unpack → edit XML → repack - see Editing Existing Documents below ^|
echo 
echo ### Converting .doc to .docx
echo 
echo Legacy `.doc` files must be converted before editing:
echo 
echo ```bash
echo python scripts/office/soffice.py --headless --convert-to docx document.doc
echo ```
echo 
echo ### Reading Content
echo 
echo ```bash
echo # Text extraction with tracked changes
echo pandoc --track-changes=all document.docx -o output.md
echo 
echo # Raw XML access
echo python scripts/office/unpack.py document.docx unpacked/
echo ```
echo 
echo ### Converting to Images
echo 
echo ```bash
echo python scripts/office/soffice.py --headless --convert-to pdf document.docx
echo pdftoppm -jpeg -r 150 document.pdf page
echo ```
echo 
echo ### Accepting Tracked Changes
echo 
echo To produce a clean document with all tracked changes accepted ^(requires LibreOffice^):
echo 
echo ```bash
echo python scripts/accept_changes.py input.docx output.docx
echo ```
echo 
echo ---
echo 
echo ## Creating New Documents
echo 
echo Generate .docx files with JavaScript, then validate. Install: `npm install -g docx`
echo 
echo ### Setup
echo ```javascript
echo const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell, ImageRun,
echo         Header, Footer, AlignmentType, PageOrientation, LevelFormat, ExternalHyperlink,
echo         InternalHyperlink, Bookmark, FootnoteReferenceRun, PositionalTab,
echo         PositionalTabAlignment, PositionalTabRelativeTo, PositionalTabLeader,
echo         TabStopType, TabStopPosition, Column, SectionType,
echo         TableOfContents, HeadingLevel, BorderStyle, WidthType, ShadingType,
echo         VerticalAlign, PageNumber, PageBreak } = require^('docx'^);
echo 
echo const doc = new Document^({ sections: [{ children: [/* content */] }] }^);
echo Packer.toBuffer^(doc^).then^(buffer =^> fs.writeFileSync^(^"doc.docx^", buffer^)^);
echo ```
echo 
echo ### Validation
echo After creating the file, validate it. If validation fails, unpack, fix the XML, and repack.
echo ```bash
echo python scripts/office/validate.py doc.docx
echo ```
echo 
echo ### Page Size
echo 
echo ```javascript
echo // CRITICAL: docx-js defaults to A4, not US Letter
echo // Always set page size explicitly for consistent results
echo sections: [{
echo   properties: {
echo     page: {
echo       size: {
echo         width: 12240,   // 8.5 inches in DXA
echo         height: 15840   // 11 inches in DXA
echo       },
echo       margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } // 1 inch margins
echo     }
echo   },
echo   children: [/* content */]
echo }]
echo ```
echo 
echo **Common page sizes ^(DXA units, 1440 DXA = 1 inch^):**
echo 
echo ^| Paper ^| Width ^| Height ^| Content Width ^(1^" margins^) ^|
echo ^|-------^|-------^|--------^|---------------------------^|
echo ^| US Letter ^| 12,240 ^| 15,840 ^| 9,360 ^|
echo ^| A4 ^(default^) ^| 11,906 ^| 16,838 ^| 9,026 ^|
echo 
echo **Landscape orientation:** docx-js swaps width/height internally, so pass portrait dimensions and let it handle the swap:
echo ```javascript
echo size: {
echo   width: 12240,   // Pass SHORT edge as width
echo   height: 15840,  // Pass LONG edge as height
echo   orientation: PageOrientation.LANDSCAPE  // docx-js swaps them in the XML
echo },
echo // Content width = 15840 - left margin - right margin ^(uses the long edge^)
echo ```
echo 
echo ### Styles ^(Override Built-in Headings^)
echo 
echo Use Arial as the default font ^(universally supported^). Keep titles black for readability.
echo 
echo ```javascript
echo const doc = new Document^({
echo   styles: {
echo     default: { document: { run: { font: ^"Arial^", size: 24 } } }, // 12pt default
echo     paragraphStyles: [
echo       // IMPORTANT: Use exact IDs to override built-in styles
echo       { id: ^"Heading1^", name: ^"Heading 1^", basedOn: ^"Normal^", next: ^"Normal^", quickFormat: true,
echo         run: { size: 32, bold: true, font: ^"Arial^" },
echo         paragraph: { spacing: { before: 240, after: 240 }, outlineLevel: 0 } }, // outlineLevel required for TOC
echo       { id: ^"Heading2^", name: ^"Heading 2^", basedOn: ^"Normal^", next: ^"Normal^", quickFormat: true,
echo         run: { size: 28, bold: true, font: ^"Arial^" },
echo         paragraph: { spacing: { before: 180, after: 180 }, outlineLevel: 1 } },
echo     ]
echo   },
echo   sections: [{
echo     children: [
echo       new Paragraph^({ heading: HeadingLevel.HEADING_1, children: [new TextRun^(^"Title^"^)] }^),
echo     ]
echo   }]
echo }^);
echo ```
echo 
echo ### Lists ^(NEVER use unicode bullets^)
echo 
echo ```javascript
echo // ❌ WRONG - never manually insert bullet characters
echo new Paragraph^({ children: [new TextRun^(^"• Item^"^)] }^)  // BAD
echo new Paragraph^({ children: [new TextRun^(^"\u2022 Item^"^)] }^)  // BAD
echo 
echo // ✅ CORRECT - use numbering config with LevelFormat.BULLET
echo const doc = new Document^({
echo   numbering: {
echo     config: [
echo       { reference: ^"bullets^",
echo         levels: [{ level: 0, format: LevelFormat.BULLET, text: ^"•^", alignment: AlignmentType.LEFT,
echo           style: { paragraph: { indent: { left: 720, hanging: 360 } } } }] },
echo       { reference: ^"numbers^",
echo         levels: [{ level: 0, format: LevelFormat.DECIMAL, text: ^"%%1.^", alignment: AlignmentType.LEFT,
echo           style: { paragraph: { indent: { left: 720, hanging: 360 } } } }] },
echo     ]
echo   },
echo   sections: [{
echo     children: [
echo       new Paragraph^({ numbering: { reference: ^"bullets^", level: 0 },
echo         children: [new TextRun^(^"Bullet item^"^)] }^),
echo       new Paragraph^({ numbering: { reference: ^"numbers^", level: 0 },
echo         children: [new TextRun^(^"Numbered item^"^)] }^),
echo     ]
echo   }]
echo }^);
echo 
echo // ⚠️ Each reference creates INDEPENDENT numbering
echo // Same reference = continues ^(1,2,3 then 4,5,6^)
echo // Different reference = restarts ^(1,2,3 then 1,2,3^)
echo ```
echo 
echo ### Tables
echo 
echo **CRITICAL: Tables need dual widths** - set both `columnWidths` on the table AND `width` on each cell. Without both, tables render incorrectly on some platforms.
echo 
echo ```javascript
echo // CRITICAL: Always set table width for consistent rendering
echo // CRITICAL: Use ShadingType.CLEAR ^(not SOLID^) to prevent black backgrounds
echo const border = { style: BorderStyle.SINGLE, size: 1, color: ^"CCCCCC^" };
echo const borders = { top: border, bottom: border, left: border, right: border };
echo 
echo new Table^({
echo   width: { size: 9360, type: WidthType.DXA }, // Always use DXA ^(percentages break in Google Docs^)
echo   columnWidths: [4680, 4680], // Must sum to table width ^(DXA: 1440 = 1 inch^)
echo   rows: [
echo     new TableRow^({
echo       children: [
echo         new TableCell^({
echo           borders,
echo           width: { size: 4680, type: WidthType.DXA }, // Also set on each cell
echo           shading: { fill: ^"D5E8F0^", type: ShadingType.CLEAR }, // CLEAR not SOLID
echo           margins: { top: 80, bottom: 80, left: 120, right: 120 }, // Cell padding ^(internal, not added to width^)
echo           children: [new Paragraph^({ children: [new TextRun^(^"Cell^"^)] }^)]
echo         }^)
echo       ]
echo     }^)
echo   ]
echo }^)
echo ```
echo 
echo **Table width calculation:**
echo 
echo Always use `WidthType.DXA` — `WidthType.PERCENTAGE` breaks in Google Docs.
echo 
echo ```javascript
echo // Table width = sum of columnWidths = content width
echo // US Letter with 1^" margins: 12240 - 2880 = 9360 DXA
echo width: { size: 9360, type: WidthType.DXA },
echo columnWidths: [7000, 2360]  // Must sum to table width
echo ```
echo 
echo **Width rules:**
echo - **Always use `WidthType.DXA`** — never `WidthType.PERCENTAGE` ^(incompatible with Google Docs^)
echo - Table width must equal the sum of `columnWidths`
echo - Cell `width` must match corresponding `columnWidth`
echo - Cell `margins` are internal padding - they reduce content area, not add to cell width
echo - For full-width tables: use content width ^(page width minus left and right margins^)
echo 
echo ### Images
echo 
echo ```javascript
echo // CRITICAL: type parameter is REQUIRED
echo new Paragraph^({
echo   children: [new ImageRun^({
echo     type: ^"png^", // Required: png, jpg, jpeg, gif, bmp, svg
echo     data: fs.readFileSync^(^"image.png^"^),
echo     transformation: { width: 200, height: 150 },
echo     altText: { title: ^"Title^", description: ^"Desc^", name: ^"Name^" } // All three required
echo   }^)]
echo }^)
echo ```
echo 
echo ### Page Breaks
echo 
echo ```javascript
echo // CRITICAL: PageBreak must be inside a Paragraph
echo new Paragraph^({ children: [new PageBreak^(^)] }^)
echo 
echo // Or use pageBreakBefore
echo new Paragraph^({ pageBreakBefore: true, children: [new TextRun^(^"New page^"^)] }^)
echo ```
echo 
echo ### Hyperlinks
echo 
echo ```javascript
echo // External link
echo new Paragraph^({
echo   children: [new ExternalHyperlink^({
echo     children: [new TextRun^({ text: ^"Click here^", style: ^"Hyperlink^" }^)],
echo     link: ^"https://example.com^",
echo   }^)]
echo }^)
echo 
echo // Internal link ^(bookmark + reference^)
echo // 1. Create bookmark at destination
echo new Paragraph^({ heading: HeadingLevel.HEADING_1, children: [
echo   new Bookmark^({ id: ^"chapter1^", children: [new TextRun^(^"Chapter 1^"^)] }^),
echo ]}^)
echo // 2. Link to it
echo new Paragraph^({ children: [new InternalHyperlink^({
echo   children: [new TextRun^({ text: ^"See Chapter 1^", style: ^"Hyperlink^" }^)],
echo   anchor: ^"chapter1^",
echo }^)]}^)
echo ```
echo 
echo ### Footnotes
echo 
echo ```javascript
echo const doc = new Document^({
echo   footnotes: {
echo     1: { children: [new Paragraph^(^"Source: Annual Report 2024^"^)] },
echo     2: { children: [new Paragraph^(^"See appendix for methodology^"^)] },
echo   },
echo   sections: [{
echo     children: [new Paragraph^({
echo       children: [
echo         new TextRun^(^"Revenue grew 15%%^"^),
echo         new FootnoteReferenceRun^(1^),
echo         new TextRun^(^" using adjusted metrics^"^),
echo         new FootnoteReferenceRun^(2^),
echo       ],
echo     }^)]
echo   }]
echo }^);
echo ```
echo 
echo ### Tab Stops
echo 
echo ```javascript
echo // Right-align text on same line ^(e.g., date opposite a title^)
echo new Paragraph^({
echo   children: [
echo     new TextRun^(^"Company Name^"^),
echo     new TextRun^(^"\tJanuary 2025^"^),
echo   ],
echo   tabStops: [{ type: TabStopType.RIGHT, position: TabStopPosition.MAX }],
echo }^)
echo 
echo // Dot leader ^(e.g., TOC-style^)
echo new Paragraph^({
echo   children: [
echo     new TextRun^(^"Introduction^"^),
echo     new TextRun^({ children: [
echo       new PositionalTab^({
echo         alignment: PositionalTabAlignment.RIGHT,
echo         relativeTo: PositionalTabRelativeTo.MARGIN,
echo         leader: PositionalTabLeader.DOT,
echo       }^),
echo       ^"3^",
echo     ]}^),
echo   ],
echo }^)
echo ```
echo 
echo ### Multi-Column Layouts
echo 
echo ```javascript
echo // Equal-width columns
echo sections: [{
echo   properties: {
echo     column: {
echo       count: 2,          // number of columns
echo       space: 720,        // gap between columns in DXA ^(720 = 0.5 inch^)
echo       equalWidth: true,
echo       separate: true,    // vertical line between columns
echo     },
echo   },
echo   children: [/* content flows naturally across columns */]
echo }]
echo 
echo // Custom-width columns ^(equalWidth must be false^)
echo sections: [{
echo   properties: {
echo     column: {
echo       equalWidth: false,
echo       children: [
echo         new Column^({ width: 5400, space: 720 }^),
echo         new Column^({ width: 3240 }^),
echo       ],
echo     },
echo   },
echo   children: [/* content */]
echo }]
echo ```
echo 
echo Force a column break with a new section using `type: SectionType.NEXT_COLUMN`.
echo 
echo ### Table of Contents
echo 
echo ```javascript
echo // CRITICAL: Headings must use HeadingLevel ONLY - no custom styles
echo new TableOfContents^(^"Table of Contents^", { hyperlink: true, headingStyleRange: ^"1-3^" }^)
echo ```
echo 
echo ### Headers/Footers
echo 
echo ```javascript
echo sections: [{
echo   properties: {
echo     page: { margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 } } // 1440 = 1 inch
echo   },
echo   headers: {
echo     default: new Header^({ children: [new Paragraph^({ children: [new TextRun^(^"Header^"^)] }^)] }^)
echo   },
echo   footers: {
echo     default: new Footer^({ children: [new Paragraph^({
echo       children: [new TextRun^(^"Page ^"^), new TextRun^({ children: [PageNumber.CURRENT] }^)]
echo     }^)] }^)
echo   },
echo   children: [/* content */]
echo }]
echo ```
echo 
echo ### Critical Rules for docx-js
echo 
echo - **Set page size explicitly** - docx-js defaults to A4; use US Letter ^(12240 x 15840 DXA^) for US documents
echo - **Landscape: pass portrait dimensions** - docx-js swaps width/height internally; pass short edge as `width`, long edge as `height`, and set `orientation: PageOrientation.LANDSCAPE`
echo - **Never use `\n`** - use separate Paragraph elements
echo - **Never use unicode bullets** - use `LevelFormat.BULLET` with numbering config
echo - **PageBreak must be in Paragraph** - standalone creates invalid XML
echo - **ImageRun requires `type`** - always specify png/jpg/etc
echo - **Always set table `width` with DXA** - never use `WidthType.PERCENTAGE` ^(breaks in Google Docs^)
echo - **Tables need dual widths** - `columnWidths` array AND cell `width`, both must match
echo - **Table width = sum of columnWidths** - for DXA, ensure they add up exactly
echo - **Always add cell margins** - use `margins: { top: 80, bottom: 80, left: 120, right: 120 }` for readable padding
echo - **Use `ShadingType.CLEAR`** - never SOLID for table shading
echo - **Never use tables as dividers/rules** - cells have minimum height and render as empty boxes ^(including in headers/footers^); use `border: { bottom: { style: BorderStyle.SINGLE, size: 6, color: ^"2E75B6^", space: 1 } }` on a Paragraph instead. For two-column footers, use tab stops ^(see Tab Stops section^), not tables
echo - **TOC requires HeadingLevel only** - no custom styles on heading paragraphs
echo - **Override built-in styles** - use exact IDs: ^"Heading1^", ^"Heading2^", etc.
echo - **Include `outlineLevel`** - required for TOC ^(0 for H1, 1 for H2, etc.^)
echo 
echo ---
echo 
echo ## Editing Existing Documents
echo 
echo **Follow all 3 steps in order.**
echo 
echo ### Step 1: Unpack
echo ```bash
echo python scripts/office/unpack.py document.docx unpacked/
echo ```
echo Extracts XML, pretty-prints, merges adjacent runs, and converts smart quotes to XML entities ^(`^&#x201C;` etc.^) so they survive editing. Use `--merge-runs false` to skip run merging.
echo 
echo ### Step 2: Edit XML
echo 
echo Edit files in `unpacked/word/`. See XML Reference below for patterns.
echo 
echo **Use ^"Claude^" as the author** for tracked changes and comments, unless the user explicitly requests use of a different name.
echo 
echo **Use the Edit tool directly for string replacement. Do not write Python scripts.** Scripts introduce unnecessary complexity. The Edit tool shows exactly what is being replaced.
echo 
echo **CRITICAL: Use smart quotes for new content.** When adding text with apostrophes or quotes, use XML entities to produce smart quotes:
echo ```xml
echo ^<!-- Use these entities for professional typography --^>
echo ^<w:t^>Here^&#x2019;s a quote: ^&#x201C;Hello^&#x201D;^</w:t^>
echo ```
echo ^| Entity ^| Character ^|
echo ^|--------^|-----------^|
echo ^| `^&#x2018;` ^| ‘ ^(left single^) ^|
echo ^| `^&#x2019;` ^| ’ ^(right single / apostrophe^) ^|
echo ^| `^&#x201C;` ^| “ ^(left double^) ^|
echo ^| `^&#x201D;` ^| ” ^(right double^) ^|
echo 
echo **Adding comments:** Use `comment.py` to handle boilerplate across multiple XML files ^(text must be pre-escaped XML^):
echo ```bash
echo python scripts/comment.py unpacked/ 0 ^"Comment text with ^&amp; and ^&#x2019;^"
echo python scripts/comment.py unpacked/ 1 ^"Reply text^" --parent 0  # reply to comment 0
echo python scripts/comment.py unpacked/ 0 ^"Text^" --author ^"Custom Author^"  # custom author name
echo ```
echo Then add markers to document.xml ^(see Comments in XML Reference^).
echo 
echo ### Step 3: Pack
echo ```bash
echo python scripts/office/pack.py unpacked/ output.docx --original document.docx
echo ```
echo Validates with auto-repair, condenses XML, and creates DOCX. Use `--validate false` to skip.
echo 
echo **Auto-repair will fix:**
echo - `durableId` ^>= 0x7FFFFFFF ^(regenerates valid ID^)
echo - Missing `xml:space=^"preserve^"` on `^<w:t^>` with whitespace
echo 
echo **Auto-repair won't fix:**
echo - Malformed XML, invalid element nesting, missing relationships, schema violations
echo 
echo ### Common Pitfalls
echo 
echo - **Replace entire `^<w:r^>` elements**: When adding tracked changes, replace the whole `^<w:r^>...^</w:r^>` block with `^<w:del^>...^<w:ins^>...` as siblings. Don't inject tracked change tags inside a run.
echo - **Preserve `^<w:rPr^>` formatting**: Copy the original run's `^<w:rPr^>` block into your tracked change runs to maintain bold, font size, etc.
echo 
echo ---
echo 
echo ## XML Reference
echo 
echo ### Schema Compliance
echo 
echo - **Element order in `^<w:pPr^>`**: `^<w:pStyle^>`, `^<w:numPr^>`, `^<w:spacing^>`, `^<w:ind^>`, `^<w:jc^>`, `^<w:rPr^>` last
echo - **Whitespace**: Add `xml:space=^"preserve^"` to `^<w:t^>` with leading/trailing spaces
echo - **RSIDs**: Must be 8-digit hex ^(e.g., `00AB1234`^)
echo 
echo ### Tracked Changes
echo 
echo **Insertion:**
echo ```xml
echo ^<w:ins w:id=^"1^" w:author=^"Claude^" w:date=^"2025-01-01T00:00:00Z^"^>
echo   ^<w:r^>^<w:t^>inserted text^</w:t^>^</w:r^>
echo ^</w:ins^>
echo ```
echo 
echo **Deletion:**
echo ```xml
echo ^<w:del w:id=^"2^" w:author=^"Claude^" w:date=^"2025-01-01T00:00:00Z^"^>
echo   ^<w:r^>^<w:delText^>deleted text^</w:delText^>^</w:r^>
echo ^</w:del^>
echo ```
echo 
echo **Inside `^<w:del^>`**: Use `^<w:delText^>` instead of `^<w:t^>`, and `^<w:delInstrText^>` instead of `^<w:instrText^>`.
echo 
echo **Minimal edits** - only mark what changes:
echo ```xml
echo ^<!-- Change ^"30 days^" to ^"60 days^" --^>
echo ^<w:r^>^<w:t^>The term is ^</w:t^>^</w:r^>
echo ^<w:del w:id=^"1^" w:author=^"Claude^" w:date=^"...^"^>
echo   ^<w:r^>^<w:delText^>30^</w:delText^>^</w:r^>
echo ^</w:del^>
echo ^<w:ins w:id=^"2^" w:author=^"Claude^" w:date=^"...^"^>
echo   ^<w:r^>^<w:t^>60^</w:t^>^</w:r^>
echo ^</w:ins^>
echo ^<w:r^>^<w:t^> days.^</w:t^>^</w:r^>
echo ```
echo 
echo **Deleting entire paragraphs/list items** - when removing ALL content from a paragraph, also mark the paragraph mark as deleted so it merges with the next paragraph. Add `^<w:del/^>` inside `^<w:pPr^>^<w:rPr^>`:
echo ```xml
echo ^<w:p^>
echo   ^<w:pPr^>
echo     ^<w:numPr^>...^</w:numPr^>  ^<!-- list numbering if present --^>
echo     ^<w:rPr^>
echo       ^<w:del w:id=^"1^" w:author=^"Claude^" w:date=^"2025-01-01T00:00:00Z^"/^>
echo     ^</w:rPr^>
echo   ^</w:pPr^>
echo   ^<w:del w:id=^"2^" w:author=^"Claude^" w:date=^"2025-01-01T00:00:00Z^"^>
echo     ^<w:r^>^<w:delText^>Entire paragraph content being deleted...^</w:delText^>^</w:r^>
echo   ^</w:del^>
echo ^</w:p^>
echo ```
echo Without the `^<w:del/^>` in `^<w:pPr^>^<w:rPr^>`, accepting changes leaves an empty paragraph/list item.
echo 
echo **Rejecting another author's insertion** - nest deletion inside their insertion:
echo ```xml
echo ^<w:ins w:author=^"Jane^" w:id=^"5^"^>
echo   ^<w:del w:author=^"Claude^" w:id=^"10^"^>
echo     ^<w:r^>^<w:delText^>their inserted text^</w:delText^>^</w:r^>
echo   ^</w:del^>
echo ^</w:ins^>
echo ```
echo 
echo **Restoring another author's deletion** - add insertion after ^(don't modify their deletion^):
echo ```xml
echo ^<w:del w:author=^"Jane^" w:id=^"5^"^>
echo   ^<w:r^>^<w:delText^>deleted text^</w:delText^>^</w:r^>
echo ^</w:del^>
echo ^<w:ins w:author=^"Claude^" w:id=^"10^"^>
echo   ^<w:r^>^<w:t^>deleted text^</w:t^>^</w:r^>
echo ^</w:ins^>
echo ```
echo 
echo ### Comments
echo 
echo After running `comment.py` ^(see Step 2^), add markers to document.xml. For replies, use `--parent` flag and nest markers inside the parent's.
echo 
echo **CRITICAL: `^<w:commentRangeStart^>` and `^<w:commentRangeEnd^>` are siblings of `^<w:r^>`, never inside `^<w:r^>`.**
echo 
echo ```xml
