echo 		Part 3 : Markup Compatibility and Extensibility
echo    --^>
echo 
echo   ^<!--  Objective 1 --^>
echo   ^<xsd:attribute name=^"Ignorable^" type=^"xsd:string^" /^>
echo 
echo   ^<!--  Objective 2 --^>
echo 	^<xsd:attribute name=^"MustUnderstand^" type=^"xsd:string^"  /^>
echo 	^<xsd:attribute name=^"ProcessContent^" type=^"xsd:string^"  /^>
echo 
echo ^<!-- An AlternateContent element shall contain one or more Choice child elements, optionally followed by a
echo Fallback child element. If present, there shall be only one Fallback element, and it shall follow all Choice
echo elements. --^>
echo 	^<xsd:element name=^"AlternateContent^"^>
echo 		^<xsd:complexType^>
echo 			^<xsd:sequence^>
echo 				^<xsd:element name=^"Choice^" minOccurs=^"0^" maxOccurs=^"unbounded^"^>
echo 					^<xsd:complexType^>
echo 						^<xsd:sequence^>
echo 							^<xsd:any minOccurs=^"0^" maxOccurs=^"unbounded^"
echo 								processContents=^"strict^"^>
echo 							^</xsd:any^>
echo 						^</xsd:sequence^>
echo 						^<xsd:attribute name=^"Requires^" type=^"xsd:string^" use=^"required^" /^>
echo 						^<xsd:attribute ref=^"mc:Ignorable^" use=^"optional^" /^>
echo 						^<xsd:attribute ref=^"mc:MustUnderstand^" use=^"optional^" /^>
echo 						^<xsd:attribute ref=^"mc:ProcessContent^" use=^"optional^" /^>
echo 					^</xsd:complexType^>
echo 				^</xsd:element^>
echo 				^<xsd:element name=^"Fallback^" minOccurs=^"0^" maxOccurs=^"1^"^>
echo 					^<xsd:complexType^>
echo 						^<xsd:sequence^>
echo 							^<xsd:any minOccurs=^"0^" maxOccurs=^"unbounded^"
echo 								processContents=^"strict^"^>
echo 							^</xsd:any^>
echo 						^</xsd:sequence^>
echo 						^<xsd:attribute ref=^"mc:Ignorable^" use=^"optional^" /^>
echo 						^<xsd:attribute ref=^"mc:MustUnderstand^" use=^"optional^" /^>
echo 						^<xsd:attribute ref=^"mc:ProcessContent^" use=^"optional^" /^>
echo 					^</xsd:complexType^>
echo 				^</xsd:element^>
echo 			^</xsd:sequence^>
echo 			^<!-- AlternateContent elements might include the attributes Ignorable,
echo 				MustUnderstand and ProcessContent described in this Part of ECMA-376. These
echo 				attributes’ qualified names shall be prefixed when associated with an AlternateContent
echo 				element. --^>
echo 			^<xsd:attribute ref=^"mc:Ignorable^" use=^"optional^" /^>
echo 			^<xsd:attribute ref=^"mc:MustUnderstand^" use=^"optional^" /^>
echo 			^<xsd:attribute ref=^"mc:ProcessContent^" use=^"optional^" /^>
